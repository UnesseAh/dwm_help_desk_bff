@userToken = <token>

POST http://localhost:3000/api/users/register
Content-Type: application/json
Authorization: Bearer {{userToken}}

{
    "user" : {
        "name" : "user1",
        "password": "123456",
        "email": "user1@mail.com"
    }
}



### 
POST http://localhost:3000/api/users/login
Content-Type: application/json

{
    "user" : {
        "name" : "user1",
        "password": "123456"
    }
}
