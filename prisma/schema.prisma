datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

// --- Enumerations ---
enum Role {
  USER
  AGENT
  ADMIN
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// --- Models ---
model User {
  id              BigInt       @id @default(autoincrement())
  name            String       @unique
  email           String       @unique
  passwordHash    String
  role            Role         @default(USER)
  createdAt       DateTime     @default(now())
  
  departmentId    BigInt?
  department      Department?  @relation(fields: [departmentId], references: [id])
  
  createdTickets  Ticket[]     @relation("ClientTickets")
  handledTickets  Ticket[]     @relation("AgentTickets")
  messages        Message[]
}

model Department {
  id       BigInt    @id @default(autoincrement())
  name     String    @unique
  users    User[]
  services Service[] 
}

model Service {
  id           BigInt     @id @default(autoincrement())
  name         String     
  tickets      Ticket[]

  departmentId BigInt
  department   Department @relation(fields: [departmentId], references: [id])

  @@unique([name, departmentId]) 
}

model Ticket {
  id           BigInt         @id @default(autoincrement())
  title        String
  description  String         @db.Text
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(LOW)
  
  tags         String[]       

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  clientId     BigInt
  client       User           @relation("ClientTickets", fields: [clientId], references: [id])

  agentId      BigInt?
  agent        User?          @relation("AgentTickets", fields: [agentId], references: [id])

  serviceId    BigInt
  service      Service        @relation(fields: [serviceId], references: [id])

  messages     Message[]
}

model Message {
  id        BigInt   @id @default(autoincrement())
  content   String   @db.Text
  createdAt DateTime @default(now())

  ticketId  BigInt
  ticket    Ticket   @relation(fields: [ticketId], references: [id])

  senderId  BigInt
  sender    User     @relation(fields: [senderId], references: [id])
}